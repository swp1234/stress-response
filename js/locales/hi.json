  "question": {
    "0": "\u091c\u092c \u0915\u094b\u0908 \u0906\u092a\u0915\u0940 \u0905\u0928\u0941\u091a\u093f\u0924 \u0906\u0932\u094b\u091a\u0928\u093e \u0915\u0930\u0924\u093e \u0939\u0948, \u0924\u094b \u0906\u092a...",
    "0a": "\u0924\u0941\u0930\u0902\u0924 \u091c\u0935\u093e\u092c \u0926\u0947\u0924\u0947 \u0939\u0948\u0902 \u0914\u0930 \u0905\u092a\u0928\u093e \u092c\u091a\u093e\u0935 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902",
    "0b": "\u091c\u093f\u0924\u0928\u0940 \u091c\u0932\u094d\u0926\u0940 \u0939\u094b \u0938\u0915\u0947 \u0909\u0938 \u0938\u094d\u0925\u093f\u0924\u093f \u0938\u0947 \u0928\u093f\u0915\u0932 \u091c\u093e\u0924\u0947 \u0939\u0948\u0902",
    "0c": "\u091c\u092e \u091c\u093e\u0924\u0947 \u0939\u0948\u0902 \u0914\u0930 \u091c\u0935\u093e\u092c \u0926\u0947\u0928\u0947 \u0915\u0947 \u0936\u092c\u094d\u0926 \u0928\u0939\u0940\u0902 \u092e\u093f\u0932\u0924\u0947",
    "0d": "\u0936\u093e\u0902\u0924\u093f \u092c\u0928\u093e\u090f \u0930\u0916\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u0909\u0928\u0938\u0947 \u0938\u0939\u092e\u0924 \u0939\u094b \u091c\u093e\u0924\u0947 \u0939\u0948\u0902",

    "1": "\u092c\u0949\u0938 \u0905\u0938\u0902\u092d\u0935 \u0921\u0947\u0921\u0932\u093e\u0907\u0928 \u0926\u0947\u0924\u093e \u0939\u0948, \u0924\u094b \u0906\u092a...",
    "1a": "\u0924\u0930\u094d\u0915 \u0926\u0947\u0924\u0947 \u0939\u0948\u0902 \u0915\u093f \u092f\u0939 \u0905\u0928\u0941\u091a\u093f\u0924 \u0939\u0948 \u0914\u0930 \u0935\u093f\u0930\u094b\u0927 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902",
    "1b": "\u0909\u0938 \u0936\u093e\u092e \u091a\u0941\u092a\u0915\u0947 \u0928\u0908 \u0928\u094c\u0915\u0930\u0940 \u0916\u094b\u091c\u0928\u0947 \u0932\u0917\u0924\u0947 \u0939\u0948\u0902",
    "1c": "\u0915\u093e\u092e \u0915\u094b \u092c\u0947\u092c\u0938\u0940 \u0938\u0947 \u0926\u0947\u0916\u0924\u0947 \u0930\u0939\u0924\u0947 \u0939\u0948\u0902, \u0936\u0941\u0930\u0942 \u0928\u0939\u0940\u0902 \u0915\u0930 \u092a\u093e\u0924\u0947",
    "1d": "\u092e\u0941\u0938\u094d\u0915\u0941\u0930\u093e\u0915\u0930 \u0915\u0939\u0924\u0947 \u0939\u0948\u0902 '\u0939\u093e\u0901, \u0915\u094b\u0908 \u0938\u092e\u0938\u094d\u092f\u093e \u0928\u0939\u0940\u0902!'",

    "2": "\u0926\u094b\u0938\u094d\u0924 \u0906\u0916\u093f\u0930\u0940 \u0938\u092e\u092f \u092a\u0930 \u092f\u094b\u091c\u0928\u093e \u0930\u0926\u094d\u0926 \u0915\u0930\u0924\u093e \u0939\u0948, \u0924\u094b \u0906\u092a...",
    "2a": "\u0909\u0928\u094d\u0939\u0947\u0902 \u091f\u094b\u0915\u0924\u0947 \u0939\u0948\u0902 \u0915\u093f \u092f\u0939 \u0917\u0932\u0924 \u0925\u093e",
    "2b": "\u0924\u0941\u0930\u0902\u0924 \u0926\u0942\u0938\u0930\u0940 \u092f\u094b\u091c\u0928\u093e \u092c\u0928\u093e\u0924\u0947 \u0939\u0948\u0902 \u0924\u093e\u0915\u093f \u0935\u094d\u092f\u0938\u094d\u0924 \u0930\u0939\u0947\u0902",
    "2c": "\u0905\u0915\u0947\u0932\u0947 \u092c\u0948\u0920\u0947 \u0930\u0939\u0924\u0947 \u0939\u0948\u0902, \u0938\u092e\u091d \u0928\u0939\u0940\u0902 \u0906\u0924\u093e \u0915\u094d\u092f\u093e \u0915\u0930\u0947\u0902",
    "2d": "\u0915\u0939\u0924\u0947 \u0939\u0948\u0902 '\u091a\u093f\u0902\u0924\u093e \u092e\u0924 \u0915\u0930\u094b!' \u0914\u0930 \u0909\u0928\u094d\u0939\u0947\u0902 \u0906\u0936\u094d\u0935\u0938\u094d\u0924 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902",

    "3": "\u0917\u0930\u092e\u093e\u0917\u0930\u092e \u092c\u0939\u0938 \u092e\u0947\u0902, \u0906\u092a...",
    "3a": "\u0914\u0930 \u091c\u094b\u0930 \u0926\u0947\u0924\u0947 \u0939\u0948\u0902 \u0914\u0930 \u092a\u0940\u091b\u0947 \u0928\u0939\u0940\u0902 \u0939\u091f\u0924\u0947",
    "3b": "\u0939\u093e\u0932\u093e\u0924 \u092c\u093f\u0917\u0921\u093c\u0928\u0947 \u0938\u0947 \u092a\u0939\u0932\u0947 \u091a\u0932\u0947 \u091c\u093e\u0924\u0947 \u0939\u0948\u0902",
    "3c": "\u092a\u0942\u0930\u0940 \u0924\u0930\u0939 \u091a\u0941\u092a \u0939\u094b \u091c\u093e\u0924\u0947 \u0939\u0948\u0902 \u0914\u0930 \u092c\u0902\u0926 \u0939\u094b \u091c\u093e\u0924\u0947 \u0939\u0948\u0902",
    "3d": "\u092e\u093e\u092b\u0940 \u092e\u093e\u0902\u0917 \u0932\u0947\u0924\u0947 \u0939\u0948\u0902 \u092d\u0932\u0947 \u0939\u0940 \u0906\u092a \u0938\u0939\u0940 \u0939\u094b\u0902",

    "4": "\u091c\u092c \u0915\u093e\u092e\u094b\u0902 \u0938\u0947 \u0926\u092c\u093e\u0935 \u092e\u0947\u0902 \u0939\u094b\u0924\u0947 \u0939\u0948\u0902, \u0924\u094b \u0906\u092a...",
    "4a": "\u092c\u093f\u0928\u093e \u0930\u0941\u0915\u0947 \u0906\u0915\u094d\u0930\u093e\u092e\u0915 \u0924\u0930\u0940\u0915\u0947 \u0938\u0947 \u0906\u0917\u0947 \u092c\u0922\u093c\u0924\u0947 \u0939\u0948\u0902",
    "4b": "\u0938\u094b\u0936\u0932 \u092e\u0940\u0921\u093f\u092f\u093e \u092f\u093e \u092d\u091f\u0915\u093e\u0935 \u092e\u0947\u0902 \u092d\u093e\u0917 \u091c\u093e\u0924\u0947 \u0939\u0948\u0902",
    "4c": "\u0938\u0942\u091a\u0940 \u0915\u094b \u0926\u0947\u0916\u0924\u0947 \u0939\u0941\u090f \u092a\u0942\u0930\u0940 \u0924\u0930\u0939 \u091c\u092e \u091c\u093e\u0924\u0947 \u0939\u0948\u0902",
    "4d": "\u092a\u0939\u0932\u0947 \u0938\u092c\u0938\u0947 \u092a\u0942\u091b\u0924\u0947 \u0939\u0948\u0902 \u0915\u093f \u0909\u0928\u094d\u0939\u0947\u0902 \u0915\u094d\u092f\u093e \u091a\u093e\u0939\u093f\u090f",

    "5": "\u0915\u094b\u0908 \u091f\u094d\u0930\u0948\u092b\u093f\u0915 \u092e\u0947\u0902 \u0906\u092a\u0915\u094b \u0915\u093e\u091f\u0924\u093e \u0939\u0948, \u0924\u094b \u0906\u092a...",
    "5a": "\u0939\u0949\u0930\u094d\u0928 \u092c\u091c\u093e\u0924\u0947 \u0939\u0948\u0902, \u091a\u093f\u0932\u094d\u0932\u093e\u0924\u0947 \u0939\u0948\u0902 \u0914\u0930 \u0909\u0928\u094d\u0939\u0947\u0902 \u092c\u0924\u093e\u0924\u0947 \u0939\u0948\u0902",
    "5b": "\u0909\u0928\u0938\u0947 \u092c\u091a\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u0926\u0942\u0938\u0930\u093e \u0930\u093e\u0938\u094d\u0924\u093e \u0932\u0947\u0924\u0947 \u0939\u0948\u0902",
    "5c": "\u0938\u094d\u091f\u0940\u092f\u0930\u093f\u0902\u0917 \u0935\u094d\u0939\u0940\u0932 \u0915\u094b \u0915\u0938\u0915\u0930 \u092a\u0915\u0921\u093c \u0932\u0947\u0924\u0947 \u0939\u0948\u0902, \u0938\u0926\u092e\u0947 \u092e\u0947\u0902 \u091c\u092e \u091c\u093e\u0924\u0947 \u0939\u0948\u0902",
    "5d": "\u0939\u093e\u0925 \u0939\u093f\u0932\u093e\u0915\u0930 \u0909\u0928\u094d\u0939\u0947\u0902 \u092a\u0939\u0932\u0947 \u091c\u093e\u0928\u0947 \u0926\u0947\u0924\u0947 \u0939\u0948\u0902",

    "6": "\u0906\u092a\u0915\u0947 \u0915\u093e\u092e \u092a\u0930 \u0915\u0921\u093c\u0940 \u092a\u094d\u0930\u0924\u093f\u0915\u094d\u0930\u093f\u092f\u093e \u092e\u093f\u0932\u0924\u0940 \u0939\u0948, \u0924\u094b \u0906\u092a...",
    "6a": "\u0905\u092a\u0928\u0947 \u092b\u0948\u0938\u0932\u094b\u0902 \u0915\u093e \u092c\u091a\u093e\u0935 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902 \u0914\u0930 \u0935\u093f\u0930\u094b\u0927 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902",
    "6b": "\u0924\u0941\u0930\u0902\u0924 \u0926\u0942\u0938\u0930\u0947 \u092a\u094d\u0930\u094b\u091c\u0947\u0915\u094d\u091f \u0916\u094b\u091c\u0928\u0947 \u0932\u0917\u0924\u0947 \u0939\u0948\u0902",
    "6c": "\u0938\u0941\u0928\u094d\u0928 \u0939\u094b\u0915\u0930 \u092c\u093e\u0930-\u092c\u093e\u0930 \u092a\u0922\u093c\u0924\u0947 \u0939\u0948\u0902, \u0938\u092e\u091d \u0928\u0939\u0940\u0902 \u092a\u093e\u0924\u0947",
    "6d": "\u0909\u0928\u094d\u0939\u0947\u0902 \u0916\u0941\u0936 \u0915\u0930\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u0938\u092c \u0915\u0941\u091b \u0926\u094b\u092c\u093e\u0930\u093e \u0932\u093f\u0916\u0924\u0947 \u0939\u0948\u0902",

    "7": "\u092c\u0921\u093c\u0947 \u091c\u0940\u0935\u0928 \u0928\u093f\u0930\u094d\u0923\u092f \u0915\u0947 \u0938\u093e\u092e\u0928\u0947, \u0906\u092a...",
    "7a": "\u091c\u0932\u094d\u0926\u0940 \u092b\u0948\u0938\u0932\u093e \u0915\u0930\u0924\u0947 \u0939\u0948\u0902 \u0914\u0930 \u092a\u0942\u0930\u0940 \u0924\u093e\u0915\u0924 \u0938\u0947 \u091c\u0941\u091f\u0924\u0947 \u0939\u0948\u0902",
    "7b": "\u091c\u093f\u0924\u0928\u093e \u0939\u094b \u0938\u0915\u0947 \u0909\u0924\u0928\u093e \u0907\u0938\u0915\u0947 \u092c\u093e\u0930\u0947 \u092e\u0947\u0902 \u0938\u094b\u091a\u0928\u0947 \u0938\u0947 \u092c\u091a\u0924\u0947 \u0939\u0948\u0902",
    "7c": "\u091a\u0941\u0928 \u0928\u0939\u0940\u0902 \u092a\u093e\u0924\u0947 \u0914\u0930 \u0905\u0928\u093f\u0936\u094d\u091a\u093f\u0924 \u0915\u093e\u0932 \u0915\u0947 \u0932\u093f\u090f \u091f\u093e\u0932\u0924\u0947 \u0930\u0939\u0924\u0947 \u0939\u0948\u0902",
