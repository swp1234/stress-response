  "question": {
    "0": "\u041a\u043e\u0433\u0434\u0430 \u0432\u0430\u0441 \u043d\u0435\u0441\u043f\u0440\u0430\u0432\u0435\u0434\u043b\u0438\u0432\u043e \u043a\u0440\u0438\u0442\u0438\u043a\u0443\u044e\u0442, \u0432\u044b...",
    "0a": "\u0421\u0440\u0430\u0437\u0443 \u0434\u0430\u0451\u0442\u0435 \u043e\u0442\u043f\u043e\u0440 \u0438 \u0437\u0430\u0449\u0438\u0449\u0430\u0435\u0442\u0435\u0441\u044c",
    "0b": "\u041a\u0430\u043a \u043c\u043e\u0436\u043d\u043e \u0431\u044b\u0441\u0442\u0440\u0435\u0435 \u043f\u043e\u043a\u0438\u0434\u0430\u0435\u0442\u0435 \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u044e",
    "0c": "\u0417\u0430\u043c\u0438\u0440\u0430\u0435\u0442\u0435 \u0438 \u043d\u0435 \u043c\u043e\u0436\u0435\u0442\u0435 \u043d\u0430\u0439\u0442\u0438 \u0441\u043b\u043e\u0432 \u0434\u043b\u044f \u043e\u0442\u0432\u0435\u0442\u0430",
    "0d": "\u0421\u043e\u0433\u043b\u0430\u0448\u0430\u0435\u0442\u0435\u0441\u044c \u0441 \u043d\u0438\u043c\u0438, \u0447\u0442\u043e\u0431\u044b \u0441\u043e\u0445\u0440\u0430\u043d\u0438\u0442\u044c \u043c\u0438\u0440",

    "1": "\u041d\u0430\u0447\u0430\u043b\u044c\u043d\u0438\u043a \u0441\u0442\u0430\u0432\u0438\u0442 \u043d\u0435\u0432\u043e\u0437\u043c\u043e\u0436\u043d\u044b\u0439 \u0434\u0435\u0434\u043b\u0430\u0439\u043d, \u0432\u044b...",
    "1a": "\u0421\u043f\u043e\u0440\u0438\u0442\u0435, \u0447\u0442\u043e \u044d\u0442\u043e \u043d\u0435\u0440\u0430\u0437\u0443\u043c\u043d\u043e, \u0438 \u0441\u043e\u043f\u0440\u043e\u0442\u0438\u0432\u043b\u044f\u0435\u0442\u0435\u0441\u044c",
    "1b": "\u0412\u0435\u0447\u0435\u0440\u043e\u043c \u0442\u0430\u0439\u043d\u043e \u043d\u0430\u0447\u0438\u043d\u0430\u0435\u0442\u0435 \u0438\u0441\u043a\u0430\u0442\u044c \u043d\u043e\u0432\u0443\u044e \u0440\u0430\u0431\u043e\u0442\u0443",
    "1c": "\u0411\u0435\u0441\u0441\u043c\u044b\u0441\u043b\u0435\u043d\u043d\u043e \u0441\u043c\u043e\u0442\u0440\u0438\u0442\u0435 \u043d\u0430 \u0437\u0430\u0434\u0430\u0447\u0443, \u043d\u0435 \u0432 \u0441\u0438\u043b\u0430\u0445 \u043d\u0430\u0447\u0430\u0442\u044c",
    "1d": "\u0413\u043e\u0432\u043e\u0440\u0438\u0442\u0435 \u00ab\u041a\u043e\u043d\u0435\u0447\u043d\u043e, \u0431\u0435\u0437 \u043f\u0440\u043e\u0431\u043b\u0435\u043c!\u00bb \u0441 \u0443\u043b\u044b\u0431\u043a\u043e\u0439",

    "2": "\u0414\u0440\u0443\u0433 \u043e\u0442\u043c\u0435\u043d\u044f\u0435\u0442 \u043f\u043b\u0430\u043d\u044b \u0432 \u043f\u043e\u0441\u043b\u0435\u0434\u043d\u0438\u0439 \u043c\u043e\u043c\u0435\u043d\u0442, \u0432\u044b...",
    "2a": "\u0412\u044b\u0441\u043a\u0430\u0437\u044b\u0432\u0430\u0435\u0442\u0435, \u0447\u0442\u043e \u044d\u0442\u043e \u043d\u0435\u0432\u043d\u0438\u043c\u0430\u0442\u0435\u043b\u044c\u043d\u043e",
    "2b": "\u0421\u0440\u0430\u0437\u0443 \u0441\u043e\u0441\u0442\u0430\u0432\u043b\u044f\u0435\u0442\u0435 \u0434\u0440\u0443\u0433\u0438\u0435 \u043f\u043b\u0430\u043d\u044b, \u0447\u0442\u043e\u0431\u044b \u0437\u0430\u043d\u044f\u0442\u044c\u0441\u044f",
    "2c": "\u0421\u0438\u0434\u0438\u0442\u0435 \u043e\u0434\u0438\u043d, \u043d\u0435 \u0437\u043d\u0430\u044f, \u0447\u0442\u043e \u0434\u0435\u043b\u0430\u0442\u044c",
    "2d": "\u0413\u043e\u0432\u043e\u0440\u0438\u0442\u0435 \u00ab\u041d\u0435 \u0432\u043e\u043b\u043d\u0443\u0439\u0441\u044f!\u00bb \u0438 \u0443\u0441\u043f\u043e\u043a\u0430\u0438\u0432\u0430\u0435\u0442\u0435 \u0438\u0445",

    "3": "\u0412 \u0440\u0430\u0437\u0433\u0430\u0440 \u0441\u0441\u043e\u0440\u044b, \u0432\u044b...",
    "3a": "\u0423\u0441\u0438\u043b\u0438\u0432\u0430\u0435\u0442\u0435 \u043d\u0430\u043f\u043e\u0440 \u0438 \u043e\u0442\u043a\u0430\u0437\u044b\u0432\u0430\u0435\u0442\u0435\u0441\u044c \u043e\u0442\u0441\u0442\u0443\u043f\u0430\u0442\u044c",
    "3b": "\u0423\u0445\u043e\u0434\u0438\u0442\u0435 \u0434\u043e \u0442\u043e\u0433\u043e, \u043a\u0430\u043a \u0432\u0441\u0451 \u043e\u0431\u043e\u0441\u0442\u0440\u0438\u0442\u0441\u044f",
    "3c": "\u041f\u043e\u043b\u043d\u043e\u0441\u0442\u044c\u044e \u0437\u0430\u043c\u043e\u043b\u043a\u0430\u0435\u0442\u0435 \u0438 \u0437\u0430\u043a\u0440\u044b\u0432\u0430\u0435\u0442\u0435\u0441\u044c",
    "3d": "\u0418\u0437\u0432\u0438\u043d\u044f\u0435\u0442\u0435\u0441\u044c, \u0434\u0430\u0436\u0435 \u043a\u043e\u0433\u0434\u0430 \u043f\u0440\u0430\u0432\u044b",

    "4": "\u041a\u043e\u0433\u0434\u0430 \u0437\u0430\u0432\u0430\u043b\u0435\u043d\u044b \u0437\u0430\u0434\u0430\u0447\u0430\u043c\u0438, \u0432\u044b...",
    "4a": "\u041f\u0440\u043e\u0440\u044b\u0432\u0430\u0435\u0442\u0435\u0441\u044c \u0430\u0433\u0440\u0435\u0441\u0441\u0438\u0432\u043d\u043e, \u0431\u0435\u0437 \u043f\u0435\u0440\u0435\u0440\u044b\u0432\u043e\u0432",
    "4b": "\u0421\u0431\u0435\u0433\u0430\u0435\u0442\u0435 \u0432 \u0441\u043e\u0446\u0441\u0435\u0442\u0438 \u0438\u043b\u0438 \u0440\u0430\u0437\u0432\u043b\u0435\u0447\u0435\u043d\u0438\u044f",
    "4c": "\u0421\u043c\u043e\u0442\u0440\u0438\u0442\u0435 \u043d\u0430 \u0441\u043f\u0438\u0441\u043e\u043a, \u043f\u043e\u043b\u043d\u043e\u0441\u0442\u044c\u044e \u043f\u0430\u0440\u0430\u043b\u0438\u0437\u043e\u0432\u0430\u043d\u044b",
    "4d": "\u0421\u043f\u0440\u0430\u0448\u0438\u0432\u0430\u0435\u0442\u0435 \u0434\u0440\u0443\u0433\u0438\u0445, \u0447\u0442\u043e \u0438\u043c \u043d\u0443\u0436\u043d\u043e \u0432 \u043f\u0435\u0440\u0432\u0443\u044e \u043e\u0447\u0435\u0440\u0435\u0434\u044c",

    "5": "\u041a\u0442\u043e-\u0442\u043e \u043f\u043e\u0434\u0440\u0435\u0437\u0430\u0435\u0442 \u0432\u0430\u0441 \u043d\u0430 \u0434\u043e\u0440\u043e\u0433\u0435, \u0432\u044b...",
    "5a": "\u0421\u0438\u0433\u043d\u0430\u043b\u0438\u0442\u0435, \u043a\u0440\u0438\u0447\u0438\u0442\u0435 \u0438 \u0434\u0430\u0451\u0442\u0435 \u0437\u043d\u0430\u0442\u044c",
    "5b": "\u0412\u044b\u0431\u0438\u0440\u0430\u0435\u0442\u0435 \u0434\u0440\u0443\u0433\u043e\u0439 \u043c\u0430\u0440\u0448\u0440\u0443\u0442, \u0447\u0442\u043e\u0431\u044b \u0438\u0437\u0431\u0435\u0436\u0430\u0442\u044c \u0438\u0445",
    "5c": "\u0412\u0446\u0435\u043f\u043b\u044f\u0435\u0442\u0435\u0441\u044c \u0432 \u0440\u0443\u043b\u044c, \u0437\u0430\u0441\u0442\u044b\u0432 \u0432 \u0448\u043e\u043a\u0435",
    "5d": "\u041c\u0430\u0445\u0430\u0435\u0442\u0435 \u0440\u0443\u043a\u043e\u0439 \u0438 \u043f\u0440\u043e\u043f\u0443\u0441\u043a\u0430\u0435\u0442\u0435 \u0438\u0445 \u0432\u043f\u0435\u0440\u0451\u0434",

    "6": "\u0412\u044b \u043f\u043e\u043b\u0443\u0447\u0430\u0435\u0442\u0435 \u0436\u0451\u0441\u0442\u043a\u0443\u044e \u043a\u0440\u0438\u0442\u0438\u043a\u0443 \u0440\u0430\u0431\u043e\u0442\u044b, \u0432\u044b...",
    "6a": "\u0417\u0430\u0449\u0438\u0449\u0430\u0435\u0442\u0435 \u0441\u0432\u043e\u0439 \u0432\u044b\u0431\u043e\u0440 \u0438 \u0434\u0430\u0451\u0442\u0435 \u043e\u0442\u043f\u043e\u0440",
    "6b": "\u0421\u0440\u0430\u0437\u0443 \u043d\u0430\u0447\u0438\u043d\u0430\u0435\u0442\u0435 \u0438\u0441\u043a\u0430\u0442\u044c \u0434\u0440\u0443\u0433\u0438\u0435 \u043f\u0440\u043e\u0435\u043a\u0442\u044b",
    "6c": "\u041f\u0435\u0440\u0435\u0447\u0438\u0442\u044b\u0432\u0430\u0435\u0442\u0435 \u0431\u0435\u0437\u0443\u0447\u0430\u0441\u0442\u043d\u043e, \u043d\u0435 \u0432 \u0441\u0438\u043b\u0430\u0445 \u043e\u0441\u043c\u044b\u0441\u043b\u0438\u0442\u044c",
    "6d": "\u041f\u0435\u0440\u0435\u043f\u0438\u0441\u044b\u0432\u0430\u0435\u0442\u0435 \u0432\u0441\u0451, \u0447\u0442\u043e\u0431\u044b \u0438\u043c \u0443\u0433\u043e\u0434\u0438\u0442\u044c",

    "7": "\u041f\u0435\u0440\u0435\u0434 \u0432\u0430\u0436\u043d\u044b\u043c \u0436\u0438\u0437\u043d\u0435\u043d\u043d\u044b\u043c \u0440\u0435\u0448\u0435\u043d\u0438\u0435\u043c, \u0432\u044b...",
    "7a": "\u0420\u0435\u0448\u0430\u0435\u0442\u0435 \u0431\u044b\u0441\u0442\u0440\u043e \u0438 \u0434\u0435\u0439\u0441\u0442\u0432\u0443\u0435\u0442\u0435 \u0440\u0435\u0448\u0438\u0442\u0435\u043b\u044c\u043d\u043e",
