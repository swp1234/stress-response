    "flighter": {
      "name": "\u0411\u0435\u0433\u043b\u0435\u0446 (Flighter)",
      "tagline": "\u0423\u0431\u0435\u0433\u0430\u0435\u0442, \u0438\u0437\u0431\u0435\u0433\u0430\u0435\u0442, \u0437\u0430\u043d\u0438\u043c\u0430\u0435\u0442\u0441\u044f \u0434\u0435\u043b\u043e\u043c, \u0447\u0442\u043e\u0431\u044b \u0443\u0431\u0435\u0436\u0430\u0442\u044c \u043e\u0442 \u0441\u0442\u0440\u0435\u0441\u0441\u0430",
      "description": "\u0412\u0430\u0448 \u0438\u043d\u0441\u0442\u0438\u043d\u043a\u0442 \u0432\u044b\u0436\u0438\u0432\u0430\u043d\u0438\u044f \u2014 \u0431\u0435\u0436\u0430\u0442\u044c. \u041d\u0435 \u0432\u0441\u0435\u0433\u0434\u0430 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u0438, \u043d\u043e \u044d\u043c\u043e\u0446\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u043e. \u041a\u043e\u0433\u0434\u0430 \u043f\u043e\u044f\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u0441\u0442\u0440\u0435\u0441\u0441, \u0432\u044b \u0443\u0431\u0435\u0433\u0430\u0435\u0442\u0435. \u041e\u0441\u0442\u0430\u0451\u0442\u0435\u0441\u044c \u0437\u0430\u043d\u044f\u0442\u044b\u043c, \u043f\u0435\u0440\u0435\u0440\u0430\u0431\u0430\u0442\u044b\u0432\u0430\u0435\u0442\u0435, \u043b\u0438\u0441\u0442\u0430\u0435\u0442\u0435 \u043b\u0435\u043d\u0442\u0443 \u0431\u0435\u0441\u043a\u043e\u043d\u0435\u0447\u043d\u043e. \u0418\u0437\u0431\u0435\u0433\u0430\u043d\u0438\u0435 \u2014 \u0432\u0430\u0448\u0430 \u0431\u0440\u043e\u043d\u044f. \u0412\u0430\u0448\u0430 \u0441\u0438\u043b\u0430 \u2014 \u0430\u0434\u0430\u043f\u0442\u0438\u0432\u043d\u043e\u0441\u0442\u044c, \u043d\u043e \u0438\u0437\u0431\u0435\u0433\u0430\u043d\u0438\u0435 \u043e\u0437\u043d\u0430\u0447\u0430\u0435\u0442, \u0447\u0442\u043e \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u044b \u043f\u0440\u043e\u0434\u043e\u043b\u0436\u0430\u044e\u0442 \u043f\u0440\u0435\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u0442\u044c.",
      "trait1": "\u0418\u0437\u0431\u0435\u0433\u0430\u0435\u0442 \u043a\u043e\u043d\u0444\u043b\u0438\u043a\u0442\u043e\u0432 \u043b\u044e\u0431\u043e\u0439 \u0446\u0435\u043d\u043e\u0439",
      "trait2": "\u0418\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0435\u0442 \u0437\u0430\u043d\u044f\u0442\u043e\u0441\u0442\u044c \u043a\u0430\u043a \u0431\u0435\u0433\u0441\u0442\u0432\u043e",
      "trait3": "\u041c\u0430\u0441\u0442\u0435\u0440 \u043e\u0442\u0432\u043b\u0435\u0447\u0435\u043d\u0438\u044f"
    },
    "freezer": {
      "name": "\u0417\u0430\u043c\u0435\u0440\u0448\u0438\u0439 (Freezer)",
      "tagline": "\u041e\u0442\u043a\u043b\u044e\u0447\u0430\u0435\u0442\u0441\u044f, \u0434\u0438\u0441\u0441\u043e\u0446\u0438\u0438\u0440\u0443\u0435\u0442, \u043d\u0435\u043c\u0435\u0435\u0442 \u043f\u043e\u0434 \u0434\u0430\u0432\u043b\u0435\u043d\u0438\u0435\u043c",
      "description": "\u041a\u043e\u0433\u0434\u0430 \u043c\u0438\u0440 \u0441\u0442\u0430\u043d\u043e\u0432\u0438\u0442\u0441\u044f \u0441\u043b\u0438\u0448\u043a\u043e\u043c \u0433\u0440\u043e\u043c\u043a\u0438\u043c, \u0432\u044b \u0437\u0430\u043c\u043e\u043b\u043a\u0430\u0435\u0442\u0435. \u0421\u0442\u0440\u0435\u0441\u0441 \u043d\u0435 \u0437\u0430\u0441\u0442\u0430\u0432\u043b\u044f\u0435\u0442 \u0432\u0430\u0441 \u0431\u043e\u0440\u043e\u0442\u044c\u0441\u044f \u0438\u043b\u0438 \u0431\u0435\u0436\u0430\u0442\u044c \u2014 \u043e\u043d \u0437\u0430\u0441\u0442\u0430\u0432\u043b\u044f\u0435\u0442 \u0437\u0430\u043c\u0435\u0440\u0435\u0442\u044c. \u0412\u044b \u043e\u0442\u043a\u043b\u044e\u0447\u0430\u0435\u0442\u0435\u0441\u044c, \u0434\u0438\u0441\u0441\u043e\u0446\u0438\u0438\u0440\u0443\u0435\u0442\u0435, \u0443\u0445\u043e\u0434\u0438\u0442\u0435 \u0432 \u0441\u0435\u0431\u044f. \u0420\u0435\u0448\u0435\u043d\u0438\u044f \u043a\u0430\u0436\u0443\u0442\u0441\u044f \u043d\u0435\u0432\u043e\u0437\u043c\u043e\u0436\u043d\u044b\u043c\u0438. \u042d\u0442\u043e \u043d\u0435 \u043b\u0435\u043d\u044c \u2014 \u044d\u0442\u043e \u0432\u0430\u0448\u0430 \u043d\u0435\u0440\u0432\u043d\u0430\u044f \u0441\u0438\u0441\u0442\u0435\u043c\u0430 \u0432\u0445\u043e\u0434\u0438\u0442 \u0432 \u0437\u0430\u0449\u0438\u0442\u043d\u044b\u0439 \u0440\u0435\u0436\u0438\u043c.",
      "trait1": "\u041f\u0430\u0440\u0430\u043b\u0438\u0437\u043e\u0432\u0430\u043d \u0440\u0435\u0448\u0435\u043d\u0438\u044f\u043c\u0438",
      "trait2": "\u0423\u0445\u043e\u0434\u0438\u0442 \u0432 \u0441\u0435\u0431\u044f \u043f\u043e\u0434 \u0434\u0430\u0432\u043b\u0435\u043d\u0438\u0435\u043c",
      "trait3": "\u0414\u0438\u0441\u0441\u043e\u0446\u0438\u0438\u0440\u0443\u0435\u0442 \u043f\u0440\u0438 \u043f\u0435\u0440\u0435\u0433\u0440\u0443\u0437\u043a\u0435"
    },
    "fawner": {
      "name": "\u0423\u0433\u043e\u0434\u043d\u0438\u043a (Fawner)",
      "tagline": "\u0423\u0433\u043e\u0436\u0434\u0430\u0435\u0442, \u0447\u0440\u0435\u0437\u043c\u0435\u0440\u043d\u043e \u043f\u043e\u0434\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u0435\u0442\u0441\u044f, \u0442\u0435\u0440\u044f\u0435\u0442 \u0441\u0435\u0431\u044f \u0440\u0430\u0434\u0438 \u043c\u0438\u0440\u0430",
      "description": "\u0412\u0430\u0448\u0430 \u0440\u0435\u0430\u043a\u0446\u0438\u044f \u043d\u0430 \u0441\u0442\u0440\u0435\u0441\u0441 \u2014 \u0441\u0442\u0430\u0442\u044c \u0442\u0435\u043c, \u043a\u0442\u043e \u043d\u0443\u0436\u0435\u043d \u0434\u0440\u0443\u0433\u0438\u043c. \u0412\u044b \u0443\u0433\u043e\u0436\u0434\u0430\u0435\u0442\u0435, \u0447\u0440\u0435\u0437\u043c\u0435\u0440\u043d\u043e \u043f\u043e\u0434\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u0435\u0442\u0435\u0441\u044c, \u0441\u043e\u0433\u043b\u0430\u0448\u0430\u0435\u0442\u0435\u0441\u044c, \u043a\u043e\u0433\u0434\u0430 \u043d\u0435 \u0441\u043e\u0433\u043b\u0430\u0441\u043d\u044b, \u0443\u043b\u044b\u0431\u0430\u0435\u0442\u0435\u0441\u044c, \u043a\u043e\u0433\u0434\u0430 \u0431\u043e\u043b\u044c\u043d\u043e. \u041a\u043e\u043d\u0444\u043b\u0438\u043a\u0442 \u0432\u0430\u0441 \u043f\u0443\u0433\u0430\u0435\u0442 \u2014 \u043d\u0435 \u043f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e \u0432\u044b \u0441\u043b\u0430\u0431\u044b, \u0430 \u043f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e \u0432\u0430\u0448\u0430 \u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u044f \u0432\u044b\u0436\u0438\u0432\u0430\u043d\u0438\u044f \u2014 \u0431\u044b\u0442\u044c \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u044b\u043c. \u0412\u044b \u0442\u043e\u0436\u0435 \u0432\u0430\u0436\u043d\u044b.",
      "trait1": "\u0413\u043e\u0432\u043e\u0440\u0438\u0442 \u00ab\u0434\u0430\u00bb, \u0438\u043c\u0435\u044f \u0432 \u0432\u0438\u0434\u0443 \u00ab\u043d\u0435\u0442\u00bb",
      "trait2": "\u0421\u0442\u0430\u0432\u0438\u0442 \u0434\u0440\u0443\u0433\u0438\u0445 \u0432\u044b\u0448\u0435 \u0441\u0435\u0431\u044f",
      "trait3": "\u0418\u0437\u0431\u0435\u0433\u0430\u0435\u0442 \u043a\u043e\u043d\u0444\u043b\u0438\u043a\u0442\u0430 \u0447\u0435\u0440\u0435\u0437 \u0443\u0441\u0442\u0443\u043f\u0447\u0438\u0432\u043e\u0441\u0442\u044c"
    }
  },
