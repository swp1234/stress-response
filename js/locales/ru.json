  "type": {
    "fighter": {
      "name": "\u0411\u043e\u0435\u0446 (Fighter)",
      "tagline": "\u041a\u043e\u043d\u0444\u0440\u043e\u043d\u0442\u0438\u0440\u0443\u0435\u0442, \u0431\u0435\u0440\u0451\u0442 \u043a\u043e\u043d\u0442\u0440\u043e\u043b\u044c, \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u044f\u0435\u0442 \u0441\u0442\u0440\u0435\u0441\u0441 \u0432 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435",
      "description": "\u041a\u043e\u0433\u0434\u0430 \u0441\u0442\u0440\u0435\u0441\u0441 \u043d\u0430\u0441\u0442\u0438\u0433\u0430\u0435\u0442, \u0432\u044b \u043d\u0435 \u043e\u0442\u0441\u0442\u0443\u043f\u0430\u0435\u0442\u0435 \u2014 \u0432\u044b \u0438\u0434\u0451\u0442\u0435 \u0432\u043f\u0435\u0440\u0451\u0434. \u0412\u0430\u0448\u0430 \u043d\u0435\u0440\u0432\u043d\u0430\u044f \u0441\u0438\u0441\u0442\u0435\u043c\u0430 \u043f\u043e \u0443\u043c\u043e\u043b\u0447\u0430\u043d\u0438\u044e \u0432\u044b\u0431\u0438\u0440\u0430\u0435\u0442 \u043a\u043e\u043d\u0444\u0440\u043e\u043d\u0442\u0430\u0446\u0438\u044e, \u043f\u0440\u0435\u0432\u0440\u0430\u0449\u0430\u044f \u0442\u0440\u0435\u0432\u043e\u0433\u0443 \u0432 \u0430\u0433\u0440\u0435\u0441\u0441\u0438\u044e, \u0430 \u0441\u0442\u0440\u0430\u0445 \u0432 \u043e\u0433\u043e\u043d\u044c. \u0412\u044b \u0441\u043f\u043e\u0440\u0438\u0442\u0435, \u0434\u0430\u0432\u0438\u0442\u0435, \u0431\u0435\u0440\u0451\u0442\u0435 \u043a\u043e\u043d\u0442\u0440\u043e\u043b\u044c. \u042d\u0442\u043e \u043c\u043e\u0436\u0435\u0442 \u0431\u044b\u0442\u044c \u043d\u0435\u0432\u0435\u0440\u043e\u044f\u0442\u043d\u043e \u0441\u0438\u043b\u044c\u043d\u044b\u043c, \u043d\u043e \u0442\u0430\u043a\u0436\u0435 \u043c\u043e\u0436\u0435\u0442 \u044d\u0441\u043a\u0430\u043b\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u043a\u043e\u043d\u0444\u043b\u0438\u043a\u0442\u044b. \u0412\u0430\u0448\u0430 \u0441\u0438\u043b\u0430 \u2014 \u0441\u043c\u0435\u043b\u043e\u0441\u0442\u044c, \u043d\u043e \u0432\u044b\u0437\u043e\u0432 \u2014 \u0437\u043d\u0430\u0442\u044c, \u043a\u043e\u0433\u0434\u0430 \u043e\u0442\u0441\u0442\u0443\u043f\u0438\u0442\u044c.",
      "trait1": "\u0420\u0435\u0448\u0430\u0435\u0442 \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u044b \u043d\u0430\u043f\u0440\u044f\u043c\u0443\u044e",
      "trait2": "\u041d\u0430\u043f\u0440\u0430\u0432\u043b\u044f\u0435\u0442 \u0441\u0442\u0440\u0435\u0441\u0441 \u0432 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435",
      "trait3": "\u041f\u0440\u0435\u0434\u043f\u043e\u0447\u0438\u0442\u0430\u0435\u0442 \u0431\u043e\u0440\u044c\u0431\u0443 \u0431\u0435\u0441\u043f\u043e\u043c\u043e\u0449\u043d\u043e\u0441\u0442\u0438"
